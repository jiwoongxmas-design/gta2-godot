; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that change here are very frequent.

config_version=5

[application]

config/name="GTA2 Godot Clone"
config/version="0.1.0"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[debug]

gdscript/warnings/unused_variable=1
gdscript/warnings/unused_argument=1

[display]

window/size/viewport_width=1024
window/size/viewport_height=768
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"

[physics]

2d/default_gravity=0.0

[input]

ui_accept={
"deadzone": 0.5,
"events": [InputEvent("ui_accept")]
}
ui_select={
"deadzone": 0.5,
"events": []
}
ui_cancel={
"deadzone": 0.5,
"events": [InputEvent("ui_cancel")]
}
ui_focus_next={
"deadzone": 0.5,
"events": [InputEvent("ui_focus_next")]
}
ui_focus_prev={
"deadzone": 0.5,
"events": [InputEvent("ui_focus_prev")]
}
ui_left={
"deadzone": 0.5,
"events": [InputEvent("ui_left")]
}
ui_right={
"deadzone": 0.5,
"events": [InputEvent("ui_right")]
}
ui_up={
"deadzone": 0.5,
"events": [InputEvent("ui_up")]
}
ui_down={
"deadzone": 0.5,
"events": [InputEvent("ui_down")]
}
